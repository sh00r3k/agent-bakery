# Shared infra contract — copy per agent to <agent>/.env and override per-agent
# fields (AGENT_NAME, POSTGRES_DB, REDIS_DB, PORT). Secrets are NEVER committed.
# (Named env.sample, not .env.example, because tooling guards block .env* paths.)
#
# From inside a container on network `agent_backend`, use service hostnames
# (postgres/redis/rabbitmq). For chat LLM + Ollama embeddings reachable on the
# host, use host.docker.internal (mapped via extra_hosts in the compose files).

# --- identity ---
AGENT_NAME=agent
ENV=prod

# --- shared Postgres (agent-postgres-1 / pgvector:pg16) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=
# POSTGRES_DB defaults to AGENT_NAME if unset
# POSTGRES_DB=

# --- shared Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED: must match REDIS_PASSWORD in the root .env (redis runs --requirepass).
REDIS_PASSWORD=
REDIS_DB=0

# --- shared RabbitMQ (alerts -> chat microservice) ---
# No guest/guest default. Fill in the RabbitMQ password (the RABBITMQ_PASS from
# the root .env) between the ':' and '@'; user defaults to appuser.
RABBITMQ_URL=amqp://appuser:@rabbitmq:5672/

# --- chat LLM: external OpenAI-compatible gateway (LiteLLM @ gateway.example.com) ---
# Model names from the gateway registry (see GET /v1/models): claude-sonnet,
# gpt-5, gemini-pro, deepseek-chat, qwen3.5-plus, glm-5.1, kimi-k2.6, grok-4.3...
LLM_BASE_URL=https://your-gateway.example.com/v1
LLM_API_KEY=
LLM_MODEL=minimax-m3
LLM_MAX_TOKENS=2048
LLM_MAX_COST_USD=0.10

# --- embeddings: local Ollama (nomic-embed-text), free ---
EMBED_BASE_URL=http://host.docker.internal:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=nomic-embed-text

# --- auth (host mints HS256 tokens; agents only verify) ---
JWT_SECRET=
# JWT_AUDIENCE=

# --- observability (OpenTelemetry OFF by default — RAM-constrained host) ---
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- server ---
HOST=0.0.0.0
PORT=8000
