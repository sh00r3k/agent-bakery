# Copy to .env and fill in. Secrets are NEVER committed.
# From inside a container on the shared `agent_backend` network, use service
# hostnames (postgres/redis/rabbitmq). For services on the host, use
# host.docker.internal (mapped via extra_hosts in the compose files).

# --- identity ---
AGENT_NAME=monitoring-agent
ENV=prod

# --- webhook ingress auth (REQUIRED in prod) ---------------------------------
# Shared HMAC-SHA256 signing secret for the /webhook/sentry + /webhook/alert
# routes. EMPTY => both webhook routes reject every request (fail-closed).
# Configure the provider to sign the raw body with this secret (Sentry sends
# `Sentry-Hook-Signature`; the generic alert route reads `X-Webhook-Signature`).
WEBHOOK_SECRET=
# Hard caps on untrusted webhook ingress.
WEBHOOK_MAX_BODY_BYTES=262144
WEBHOOK_MAX_ALERTS=50

# --- triage prompt branding --------------------------------------------------
# The user-facing product the SRE-triage LLM prompt reasons about.
MONITORING_BRAND=the monitored service

# --- health sweep: probe public surfaces -------------------------------------
POLL_INTERVAL_SECONDS=60
# JSON list of URLs to probe each sweep.
TARGETS=["https://example.com","https://api.example.com"]
SLOW_THRESHOLD_SECONDS=2.0
CERT_WARN_DAYS=14
PROBE_TIMEOUT_SECONDS=10.0
DEDUP_WINDOW_MINUTES=30

# --- meta-monitoring: watch your agents + infra -------------------------------
META_ENABLED=true
META_POLL_INTERVAL_SECONDS=120
# JSON map of agent -> base URL for /healthz + /readyz scraping (http(s) only).
# The monitor does NOT scrape itself (a dead process can't report it's dead).
AGENT_ENDPOINTS={"dashboard":"http://dashboard:8000"}
# Read-only docker-socket-proxy (GET verbs only; NEVER the raw socket).
DOCKER_PROXY_URL=http://docker-socket-proxy:2375
WATCHED_CONTAINERS=["monitoring_agent","dashboard","agent-postgres-1","agent-redis-1","agent-rabbitmq-1"]
# Cross-DB heartbeat sources (read-only): agent -> {db,table,job,interval_s}.
HEARTBEAT_SOURCES={}
# RabbitMQ management API for unconsumed-queue-depth (alert-delivery canary).
RABBIT_MGMT_URL=http://agent-rabbitmq-1:15672
WATCHED_QUEUES=["agent.alerts.chat"]
QUEUE_DEPTH_THRESHOLD=100

# --- shared Postgres / Redis / RabbitMQ ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=
POSTGRES_DB=monitoring
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED: must match REDIS_PASSWORD in the root .env (redis runs --requirepass).
REDIS_PASSWORD=
# Distinct logical DB so keys never collide with sibling agents (settings default).
REDIS_DB=2
# No guest/guest default. Fill in the RabbitMQ password (the RABBITMQ_PASS from
# the root .env) between the ':' and '@'; user defaults to appuser.
RABBITMQ_URL=amqp://appuser:@rabbitmq:5672/

# --- auth ---
JWT_SECRET=

# --- observability (OpenTelemetry OFF by default) ---
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- server ---
HOST=0.0.0.0
PORT=8000
