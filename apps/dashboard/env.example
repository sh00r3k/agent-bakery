# Copy to .env and fill in. Secrets are NEVER committed.

# --- identity ---
AGENT_NAME=dashboard
ENV=prod
POSTGRES_DB=dashboard
REDIS_DB=4

# --- shared Postgres / Redis / RabbitMQ ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED: must match REDIS_PASSWORD in the root .env (redis runs --requirepass).
REDIS_PASSWORD=
# No guest/guest default. Fill in the RabbitMQ password (the RABBITMQ_PASS from
# the root .env) between the ':' and '@'; user defaults to appuser.
RABBITMQ_URL=amqp://appuser:@rabbitmq:5672/

# --- chat LLM: any OpenAI-compatible gateway ---
LLM_BASE_URL=https://your-gateway.example.com/v1
LLM_API_KEY=
LLM_MODEL=your-model
LLM_MAX_TOKENS=2048
LLM_MAX_COST_USD=0.10

# --- embeddings: local Ollama (free) ---
EMBED_BASE_URL=http://host.docker.internal:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=nomic-embed-text

# --- auth (host mints HS256 tokens; agents only verify) ---
JWT_SECRET=
# JWT_AUDIENCE=

# --- observability (OpenTelemetry OFF by default) ---
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- server ---
HOST=0.0.0.0
PORT=8000

# --- dashboard: agent registry (FULLY config-driven) ---
# The dashboard observes whatever agents you declare here — ANY composition.
# DASHBOARD_AGENTS is a JSON array of objects:
#   slug     (required) stable id used in URLs / cache keys
#   url      (required) in-cluster base URL (service hostname over the shared net)
#   kind     server | batch | self            (default: server)
#   title    display name shown on the tile    (default: slug)
#   port     host loopback port shown on the tile (default: 0; batch = no port)
#   features capabilities the agent exposes; drives which panels/links render.
#            recognized: incidents | findings | coverage | runs | pm
# Leave unset/empty to use the built-in example agents. Must be single-line JSON.
DASHBOARD_AGENTS=[{"slug":"monitoring","title":"monitoring","url":"http://monitoring:8000","port":8002,"kind":"server","features":["incidents"]},{"slug":"dashboard","title":"dashboard (self)","url":"http://dashboard:8000","port":8005,"kind":"self"}]

# --- dashboard: session cookie + upstream token + aggregation ---
SESSION_COOKIE_NAME=agents_dash
SESSION_COOKIE_SECURE=true
UPSTREAM_TOKEN_TTL_S=3600
UPSTREAM_TOKEN_SUB=dashboard
UPSTREAM_TIMEOUT_S=3.0
CACHE_TTL_S=8
