# Root distribution env — copy to .env (`cp env.example .env`). Secrets are
# NEVER committed (BR-010). This file holds ONLY the knobs the root
# docker-compose.yml interpolates; per-agent secrets live in each member's .env
# (agents/<name>/.env, apps/dashboard/.env) — see infra/env.example.
#
# (Named env.example, not .env.example, because tooling guards block .env* paths.)

# --- image distribution ------------------------------------------------------
# Pulled image: ${REGISTRY}/<svc>:${IMAGE_TAG}. Pin IMAGE_TAG to a released
# version (e.g. v0.2.3) per docs/architecture.md versioning policy — never run
# `latest` in prod. To build from source instead, uncomment each service's
# build: stanza (or use docker-compose.build.yml).
REGISTRY=ghcr.io/acme/agent-bakery
IMAGE_TAG=v0.2.0

# --- shared Postgres superuser (agent-postgres-1 / pgvector:pg16) ------------
# POSTGRES_PASSWORD is REQUIRED (compose fails fast if unset). It must match the
# POSTGRES_PASSWORD in every per-agent .env.
POSTGRES_USER=appuser
POSTGRES_PASSWORD=

# --- shared Redis ------------------------------------------------------------
# REDIS_PASSWORD is REQUIRED (compose fails fast if unset). redis-server runs
# with --requirepass; every agent must set the SAME REDIS_PASSWORD in its .env.
REDIS_PASSWORD=

# --- shared RabbitMQ ---------------------------------------------------------
# Username defaults to appuser. RABBITMQ_PASS is REQUIRED (compose fails fast if
# unset) — there is NO guest/guest fallback. Pick a real password the same way
# as POSTGRES_PASSWORD, and use it in the amqp:// URL in every per-agent .env.
RABBITMQ_USER=appuser
RABBITMQ_PASS=
